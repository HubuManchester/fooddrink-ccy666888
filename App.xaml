<?xml version="1.0" encoding="UTF-8" ?>
<Application 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:TasteHub.Converters"
    x:Class="TasteHub.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Brand colours: consistent theme across all pages -->
            <Color x:Key="Primary">#7BA38E</Color>
            <Color x:Key="Secondary">#DFD8F7</Color>
            <Color x:Key="Tertiary">#2B0B98</Color>

            <!-- Base colours -->
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="Black">#000000</Color>

            <!-- Neutral grey scale for text, borders and backgrounds -->
            <Color x:Key="Gray100">#F5F5F5</Color>
            <Color x:Key="Gray200">#EEEEEE</Color>
            <Color x:Key="Gray300">#BDBDBD</Color>
            <Color x:Key="Gray400">#9E9E9E</Color>
            <Color x:Key="Gray500">#757575</Color>
            <Color x:Key="Gray600">#616161</Color>
            <Color x:Key="Gray900">#212121</Color>
            <Color x:Key="Gray950">#1A1A1A</Color>

            <!-- Accent colours for highlights and decorations -->
            <Color x:Key="Yellow100Accent">#F7B548</Color>
            <Color x:Key="Yellow200Accent">#FFD590</Color>
            <Color x:Key="Yellow300Accent">#FFE5B9</Color>
            <Color x:Key="Cyan100Accent">#28C2D1</Color>
            <Color x:Key="Cyan200Accent">#7BDDEF</Color>
            <Color x:Key="Cyan300Accent">#C3F2F4</Color>

            <!-- Dynamic font sizes: updated at runtime via Settings page (WCAG 1.4.4) -->
            <x:Double x:Key="AppFontSizeSmall">14</x:Double>
            <x:Double x:Key="AppFontSize">16</x:Double>
            <x:Double x:Key="AppFontSizeLarge">20</x:Double>
            <x:Double x:Key="AppFontSizeTitle">24</x:Double>

            <!-- Reusable XAML value converters registered globally for data binding -->
            <converters:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <converters:IsNotEmptyConverter x:Key="IsNotEmptyConverter"/>
            <converters:BoolToTTSTextConverter x:Key="BoolToTTSTextConverter"/>
            <converters:BoolToSaveTextConverter x:Key="BoolToSaveTextConverter"/>
            <converters:PercentToDoubleConverter x:Key="PercentToDoubleConverter"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
            <converters:StepIndexConverter x:Key="StepIndexConverter"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>