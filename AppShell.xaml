<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TasteHub.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TasteHub.Views"
    Title="TasteHub"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#7BA38E"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
    Shell.TabBarForegroundColor="#7BA38E"
    Shell.TabBarUnselectedColor="#B0B0B0"
    Shell.TabBarTitleColor="#7BA38E">

    <TabBar>
        <Tab Title="Home" Icon="home_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage"/>
        </Tab>
        <Tab Title="Add" Icon="add_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:AddEditPage}" Route="AddEditPage"/>
        </Tab>
        <Tab Title="Settings" Icon="settings_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage"/>
        </Tab>
    </TabBar>
</Shell>