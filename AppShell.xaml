<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TasteHub.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TasteHub.Views"
    Title="TasteHub"
    Shell.FlyoutBehavior="Disabled">

    <!-- Bottom Tab Navigation -->
    <TabBar>
        <ShellContent
            Title="Home"
            Icon="home_icon.png"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="HomePage"
            SemanticProperties.Description="Home page with recipe list"/>

        <ShellContent
            Title="Add"
            Icon="add_icon.png"
            ContentTemplate="{DataTemplate views:AddEditPage}"
            Route="AddEditPage"
            SemanticProperties.Description="Add a new recipe"/>

        <ShellContent
            Title="Settings"
            Icon="settings_icon.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage"
            SemanticProperties.Description="App settings and accessibility"/>
    </TabBar>

</Shell>