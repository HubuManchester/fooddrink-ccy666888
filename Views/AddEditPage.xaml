<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TasteHub.ViewModels"
             x:Class="TasteHub.Views.AddEditPage"
             x:DataType="viewmodels:AddEditViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#FDFCFA, Dark=#1A1A1A}"
             SemanticProperties.Description="Page for adding or editing a recipe">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="12">

            <!-- Recipe Name -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Recipe Name *" FontAttributes="Bold"
                       FontSize="{DynamicResource AppFontSize}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                <Frame CornerRadius="10" Padding="0" HasShadow="False"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                       BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                    <Entry Placeholder="Enter recipe name" Text="{Binding RecipeName}" MaxLength="100"
                           BackgroundColor="Transparent"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"
                           PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                           Margin="10,0"/>
                </Frame>
                <Label Text="{Binding NameError}" TextColor="#D9534F"
                       FontSize="{DynamicResource AppFontSizeSmall}"
                       IsVisible="{Binding NameError, Converter={StaticResource IsNotEmptyConverter}}"/>
            </VerticalStackLayout>

            <!-- Category -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Category *" FontAttributes="Bold"
                       FontSize="{DynamicResource AppFontSize}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                <Frame CornerRadius="10" Padding="0" HasShadow="False"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                       BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                    <Picker Title="Select category" ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"
                            BackgroundColor="Transparent" Margin="6,0"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Sub-Category -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Sub-Category *" FontAttributes="Bold"
                       FontSize="{DynamicResource AppFontSize}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                <Frame CornerRadius="10" Padding="0" HasShadow="False"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                       BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                    <Picker Title="Select sub-category" ItemsSource="{Binding SubCategories}"
                            SelectedItem="{Binding SelectedSubCategory}"
                            TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"
                            BackgroundColor="Transparent" Margin="6,0"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Description -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Description" FontAttributes="Bold"
                       FontSize="{DynamicResource AppFontSize}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                <Frame CornerRadius="10" Padding="0" HasShadow="False"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}"
                       BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                    <Editor Placeholder="Describe your recipe..." Text="{Binding Description}"
                            HeightRequest="80" MaxLength="500"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"
                            PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                            Margin="10,5"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Cover Image -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Cover Image" FontAttributes="Bold"
                       FontSize="{DynamicResource AppFontSize}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                <Frame CornerRadius="12" Padding="0" IsClippedToBounds="True"
                       HeightRequest="160" HasShadow="False"
                       BackgroundColor="{AppThemeBinding Light=#F5F3EF, Dark=#262626}">
                    <Image Source="{Binding ImagePath}" Aspect="AspectFill"/>
                </Frame>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="Take Photo"
                            Command="{Binding TakePhotoCommand}"
                            BackgroundColor="{AppThemeBinding Light=#B8C9D9, Dark=#4A5A6A}"
                            TextColor="White"
                            CornerRadius="10" FontSize="14"/>
                    <Button Grid.Column="1" Text="Gallery"
                            Command="{Binding PickPhotoCommand}"
                            BackgroundColor="{AppThemeBinding Light=#C8BFB4, Dark=#4A4A4A}"
                            TextColor="White"
                            CornerRadius="10" FontSize="14"/>
                </Grid>
                <Button Text="Scan Food with AI"
                        Command="{Binding ScanFoodCommand}"
                        BackgroundColor="#7BA38E" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <!-- Nutrition -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#F0F7F2, Dark=#222E26}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Nutrition Information" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Grid.Row="0">
                            <Label Text="Calories (kcal)" FontSize="{DynamicResource AppFontSizeSmall}"
                                   TextColor="{AppThemeBinding Light=#5A5A5A, Dark=#C8C8C8}"/>
                            <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                                   BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                                <Entry Placeholder="0" Text="{Binding CaloriesText}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="10,0"
                                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                            </Frame>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Grid.Row="0">
                            <Label Text="Protein (g)" FontSize="{DynamicResource AppFontSizeSmall}"
                                   TextColor="{AppThemeBinding Light=#5A5A5A, Dark=#C8C8C8}"/>
                            <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                                   BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                                <Entry Placeholder="0" Text="{Binding ProteinText}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="10,0"
                                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                            </Frame>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="0" Grid.Row="1">
                            <Label Text="Carbs (g)" FontSize="{DynamicResource AppFontSizeSmall}"
                                   TextColor="{AppThemeBinding Light=#5A5A5A, Dark=#C8C8C8}"/>
                            <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                                   BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                                <Entry Placeholder="0" Text="{Binding CarbsText}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="10,0"
                                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                            </Frame>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Grid.Row="1">
                            <Label Text="Fat (g)" FontSize="{DynamicResource AppFontSizeSmall}"
                                   TextColor="{AppThemeBinding Light=#5A5A5A, Dark=#C8C8C8}"/>
                            <Frame CornerRadius="8" Padding="0" HasShadow="False"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                                   BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                                <Entry Placeholder="0" Text="{Binding FatText}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="10,0"
                                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                            </Frame>
                        </VerticalStackLayout>
                    </Grid>
                    <Label Text="{Binding NutritionError}" TextColor="#D9534F"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           IsVisible="{Binding NutritionError, Converter={StaticResource IsNotEmptyConverter}}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Ingredients -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#2A2520}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Ingredients *" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Frame Grid.Column="0" CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                               BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                            <Entry Placeholder="Add an ingredient" Text="{Binding NewIngredient}"
                                   BackgroundColor="Transparent" Margin="10,0"
                                   TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                        </Frame>
                        <Button Grid.Column="1" Text="+" WidthRequest="45"
                                Command="{Binding AddIngredientCommand}"
                                BackgroundColor="#7BA38E" TextColor="White"
                                CornerRadius="10" FontSize="20" Padding="0"/>
                    </Grid>
                    <Label Text="{Binding IngredientsError}" TextColor="#D9534F"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           IsVisible="{Binding IngredientsError, Converter={StaticResource IsNotEmptyConverter}}"/>
                    <CollectionView ItemsSource="{Binding Ingredients}" HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnDefinitions="*,Auto" Padding="4,4">
                                    <Label Grid.Column="0" Text="{Binding .}"
                                           FontSize="{DynamicResource AppFontSize}" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                                    <Button Grid.Column="1" Text="✕"
                                            WidthRequest="30" HeightRequest="30" FontSize="12" Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AddEditViewModel}}, Path=RemoveIngredientCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light=#E0D6CE, Dark=#4A4A4A}"
                                            TextColor="{AppThemeBinding Light=#8A8A8A, Dark=#C0C0C0}"
                                            CornerRadius="15"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Steps -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#E8EAF6, Dark=#252530}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Steps *" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Frame Grid.Column="0" CornerRadius="10" Padding="0" HasShadow="False"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}"
                               BorderColor="{AppThemeBinding Light=#D5CEC6, Dark=#4A4A4A}">
                            <Entry Placeholder="Add a step" Text="{Binding NewStep}"
                                   BackgroundColor="Transparent" Margin="10,0"
                                   TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                        </Frame>
                        <Button Grid.Column="1" Text="+" WidthRequest="45"
                                Command="{Binding AddStepCommand}"
                                BackgroundColor="#7BA38E" TextColor="White"
                                CornerRadius="10" FontSize="20" Padding="0"/>
                    </Grid>
                    <Label Text="{Binding StepsError}" TextColor="#D9534F"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           IsVisible="{Binding StepsError, Converter={StaticResource IsNotEmptyConverter}}"/>
                    <CollectionView ItemsSource="{Binding Steps}" HeightRequest="150">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnDefinitions="*,Auto" Padding="4,4">
                                    <Label Grid.Column="0" Text="{Binding .}"
                                           FontSize="{DynamicResource AppFontSize}" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#E8E8E8}"/>
                                    <Button Grid.Column="1" Text="✕"
                                            WidthRequest="30" HeightRequest="30" FontSize="12" Padding="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AddEditViewModel}}, Path=RemoveStepCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light=#E0D6CE, Dark=#4A4A4A}"
                                            TextColor="{AppThemeBinding Light=#8A8A8A, Dark=#C0C0C0}"
                                            CornerRadius="15"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Save -->
            <Button Text="{Binding IsEditMode, Converter={StaticResource BoolToSaveTextConverter}}"
                    Command="{Binding SaveRecipeCommand}"
                    BackgroundColor="#7BA38E" TextColor="White"
                    FontAttributes="Bold" CornerRadius="12" HeightRequest="52"
                    FontSize="{DynamicResource AppFontSize}" Margin="0,10"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>