<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TasteHub.ViewModels"
             x:Class="TasteHub.Views.DetailPage"
             x:DataType="viewmodels:DetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#FDFCFA, Dark=#1A1A1A}"
             SemanticProperties.Description="Recipe detail page showing full recipe information">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="12">

            <!-- Cover image -->
            <Frame CornerRadius="14" Padding="0" HeightRequest="280" HasShadow="True"
                   BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#F5F3EF, Dark=#262626}">
                <Image Source="{Binding Recipe.ImagePath}"
                       Aspect="AspectFit" x:Name="RecipeImage" HeightRequest="280">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnImageDoubleTapped"/>
                    </Image.GestureRecognizers>
                </Image>
            </Frame>

            <!-- Zoom buttons below image -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Button Text="−  Zoom Out" Clicked="OnZoomOutClicked"
                        BackgroundColor="{AppThemeBinding Light=#EDE8E2, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"
                        CornerRadius="18" HeightRequest="36" FontSize="13" Padding="12,0"/>
                <Button Text="+  Zoom In" Clicked="OnZoomInClicked"
                        BackgroundColor="{AppThemeBinding Light=#EDE8E2, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"
                        CornerRadius="18" HeightRequest="36" FontSize="13" Padding="12,0"/>
                <Button Text="↺  Reset" Clicked="OnZoomResetClicked"
                        BackgroundColor="{AppThemeBinding Light=#EDE8E2, Dark=#3A3A3A}"
                        TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"
                        CornerRadius="18" HeightRequest="36" FontSize="13" Padding="12,0"/>
            </HorizontalStackLayout>

            <!-- Name and category -->
            <VerticalStackLayout Spacing="4">
                <Label Text="{Binding Recipe.Name}"
                       FontSize="{DynamicResource AppFontSizeTitle}" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                       SemanticProperties.HeadingLevel="Level1"/>
                <HorizontalStackLayout Spacing="8">
                    <Frame Padding="8,4" CornerRadius="10" HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#2E4A3A}">
                        <Label Text="{Binding Recipe.Category}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#C8E6C9}"/>
                    </Frame>
                    <Frame Padding="8,4" CornerRadius="10" HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#4A3728}">
                        <Label Text="{Binding Recipe.SubCategory}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#FFE0B2}"/>
                    </Frame>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Description -->
            <Label Text="{Binding Recipe.Description}"
                   FontSize="{DynamicResource AppFontSize}"
                   TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>

            <!-- Nutrition -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#F0F7F2, Dark=#1E2E24}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Nutrition Information" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                        <Label Grid.Column="0" Text="Calories" FontAttributes="Bold"
                               FontSize="{DynamicResource AppFontSizeSmall}" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                        <Label Grid.Column="1" Text="Protein" FontAttributes="Bold"
                               FontSize="{DynamicResource AppFontSizeSmall}" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                        <Label Grid.Column="2" Text="Carbs" FontAttributes="Bold"
                               FontSize="{DynamicResource AppFontSizeSmall}" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                        <Label Grid.Column="3" Text="Fat" FontAttributes="Bold"
                               FontSize="{DynamicResource AppFontSizeSmall}" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                        <Label Grid.Row="1" Grid.Column="0" HorizontalTextAlignment="Center"
                               Text="{Binding Recipe.Calories, StringFormat='{0:F0} kcal'}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"/>
                        <Label Grid.Row="1" Grid.Column="1" HorizontalTextAlignment="Center"
                               Text="{Binding Recipe.Protein, StringFormat='{0:F1}g'}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"/>
                        <Label Grid.Row="1" Grid.Column="2" HorizontalTextAlignment="Center"
                               Text="{Binding Recipe.Carbs, StringFormat='{0:F1}g'}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"/>
                        <Label Grid.Row="1" Grid.Column="3" HorizontalTextAlignment="Center"
                               Text="{Binding Recipe.Fat, StringFormat='{0:F1}g'}"
                               FontSize="{DynamicResource AppFontSizeSmall}"
                               TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Ingredients -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#FFF8F0, Dark=#2E2820}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Ingredients" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <CollectionView ItemsSource="{Binding IngredientsList}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <HorizontalStackLayout Spacing="8" Padding="0,3">
                                    <Label Text="•" FontSize="{DynamicResource AppFontSize}"
                                           TextColor="#E8A87C"/>
                                    <Label Text="{Binding .}" FontSize="{DynamicResource AppFontSize}"
                                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Steps with TTS -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#F5F3EF, Dark=#252525}">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Steps" FontAttributes="Bold"
                               FontSize="{DynamicResource AppFontSize}"
                               TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                               SemanticProperties.HeadingLevel="Level2"/>
                        <Button Grid.Column="1" x:Name="TtsButton"
                                Text="🔊 Read Aloud" Clicked="OnTtsButtonClicked"
                                BackgroundColor="#7BA38E" TextColor="White"
                                CornerRadius="10" FontSize="13"
                                SemanticProperties.Hint="Read cooking steps aloud"/>
                    </Grid>
                    <CollectionView ItemsSource="{Binding StepsList}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Frame Padding="10" Margin="0,3" CornerRadius="10" HasShadow="False"
                                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}">
                                    <Label Text="{Binding .}" FontSize="{DynamicResource AppFontSize}"
                                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Edit"
                        Command="{Binding EditRecipeCommand}"
                        BackgroundColor="#E8A87C" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"/>
                <Button Grid.Column="1" Text="Delete"
                        Command="{Binding DeleteRecipeCommand}"
                        BackgroundColor="#D9897A" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"/>
                <Button Grid.Column="2" Text="Cook!"
                        Clicked="OnCookClicked"
                        BackgroundColor="#7BA38E" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>