<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TasteHub.ViewModels"
             x:Class="TasteHub.Views.SettingsPage"
             x:DataType="viewmodels:SettingsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#FDFCFA, Dark=#1A1A1A}"
             SemanticProperties.Description="Settings page for theme font size and accessibility">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="15">

            <!-- Theme -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#262626}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Theme" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSizeLarge}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Dark Mode"
                               FontSize="{DynamicResource AppFontSize}" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                        <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"
                                OnColor="#7BA38E"
                                SemanticProperties.Hint="Toggle between dark and light theme"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Font Size -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#262626}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Font Size" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSizeLarge}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Label Text="{Binding SelectedFontSize, StringFormat='Current: {0}'}"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"
                           FontAttributes="Bold"/>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Grid.Column="0" Grid.Row="0" Text="Small"
                                Command="{Binding SetFontSmallCommand}"
                                BackgroundColor="#95B8D1" TextColor="White" CornerRadius="10"/>
                        <Button Grid.Column="1" Grid.Row="0" Text="Medium"
                                Command="{Binding SetFontMediumCommand}"
                                BackgroundColor="#7BA38E" TextColor="White" CornerRadius="10"/>
                        <Button Grid.Column="0" Grid.Row="1" Text="Large"
                                Command="{Binding SetFontLargeCommand}"
                                BackgroundColor="#E8A87C" TextColor="White" CornerRadius="10"/>
                        <Button Grid.Column="1" Grid.Row="1" Text="Extra Large"
                                Command="{Binding SetFontExtraLargeCommand}"
                                BackgroundColor="#DEB887" TextColor="White" CornerRadius="10"/>
                    </Grid>
                    <Frame Padding="12" CornerRadius="10" HasShadow="False"
                           BackgroundColor="{AppThemeBinding Light=#F5F3EF, Dark=#2D2D2D}">
                        <Label Text="This is a preview of the selected font size."
                               FontSize="{Binding FontSizeValue}"
                               TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Accessibility -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#F0F7F2, Dark=#1E2E24}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Accessibility" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSizeLarge}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Label Text="TasteHub follows WCAG 2.1 guidelines for an inclusive experience."
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#D5CEC6, Dark=#3A3A3A}"/>
                    <Label Text="WCAG Principles Applied:" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#7BA38E, Dark=#A3C9B3}"/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="1.1.1 Non-text Content - All images have semantic descriptions."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="1.3.1 Info and Relationships - Semantic headings and labels."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="1.4.3 Contrast - Text meets 4.5:1 contrast ratio."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="1.4.4 Resize Text - Font adjustable: Small to Extra Large."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="2.1.1 Keyboard Accessible - All elements navigable."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="2.4.2 Page Titled - Each page has a clear title."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="3.3.1 Error Identification - Errors identify the problem field."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="3.3.2 Labels or Instructions - Every input has a visible label."/>
                    <Label FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#D0D0D0}"
                           Text="4.1.2 Name Role Value - Semantic properties on all elements."/>
                </VerticalStackLayout>
            </Frame>

            <!-- Help -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=#FFF8F0, Dark=#2E2820}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Help" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSizeLarge}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Browse recipes on the Home tab using filters."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Tap a recipe card to view full details."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Swipe left on a recipe to edit or delete it."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Tap the speaker icon to hear steps read aloud."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Tap Cook to enter interactive mode using sensors."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Shake your phone on the Home page to earn a coupon."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label FontSize="{DynamicResource AppFontSize}"
                           Text="Use Scan Food with AI to auto-fill recipes."
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- About -->
            <Frame CornerRadius="14" Padding="15" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#262626}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="About TasteHub" FontAttributes="Bold"
                           FontSize="{DynamicResource AppFontSizeLarge}"
                           TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F0F0F0}"
                           SemanticProperties.HeadingLevel="Level2"/>
                    <Label Text="A cross-platform food and drink recipe app built with .NET MAUI."
                           FontSize="{DynamicResource AppFontSize}"
                           TextColor="{AppThemeBinding Light=#3D3D3D, Dark=#E8E8E8}"/>
                    <Label Text="Version 1.0.0 | Changyu Chen | 20906256"
                           FontSize="{DynamicResource AppFontSizeSmall}"
                           TextColor="{AppThemeBinding Light=#8A8A8A, Dark=#A8A8A8}"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>